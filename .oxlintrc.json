{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "categories": {
        "correctness": "error"
    },
    "env": {
        "browser": true,
        "builtin": true,
        "es2024": true,
        "jest": true,
        "node": true
    },
    "ignorePatterns": ["**/declarations/", "**/dist/", "**/doc/", "**/lib/"],
    "plugins": ["jest", "typescript"],
    "rules": {
        "no-shadow-restricted-names": "off"
    }
}
